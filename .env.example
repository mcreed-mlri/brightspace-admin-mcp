# Copy this file to .env and fill in the values from your Brightspace OAuth app registration.
# (Admin Tools -> Manage Extensibility -> OAuth 2.0 -> Register an app)

# Your Brightspace instance, no trailing slash
BRIGHTSPACE_INSTANCE_URL=https://YOURSCHOOL.brightspace.com

# From the app registration screen
BRIGHTSPACE_CLIENT_ID=
BRIGHTSPACE_CLIENT_SECRET=

# Must match the scopes you registered (space-delimited). Read-only starter set.
# core:*:* is REQUIRED (whoami, outypes, and other core actions reject core:*:read).
# Write it with BOTH colons: core:*:*  (a missing colon like core*:* is what D2L rejects).
BRIGHTSPACE_SCOPE=core:*:* users:userdata:read users:own:read organizations:organization:read enrollment:enrollment:read enrollment:orgunit:read enrollment:own:read grades:gradeobjects:read grades:gradevalues:read datahub:dataexports:read

# Must EXACTLY match a redirect URI you registered.
# Brightspace requires HTTPS; authorize.py serves localhost over TLS with a self-signed cert.
BRIGHTSPACE_REDIRECT_URI=https://localhost:3000/callback

# Where the rotating refresh token is stored (relative to project root is fine)
BRIGHTSPACE_TOKEN_FILE=.tokens.json

# API versions. Run `python scripts/smoke.py --versions` to see what your instance supports.
# Leave blank to auto-discover the latest supported version on first use.
BRIGHTSPACE_LP_VERSION=
BRIGHTSPACE_LE_VERSION=
